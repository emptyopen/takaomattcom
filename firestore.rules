rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Feature flags: anyone (including unauthenticated mobile clients) may read.
    // Only the admin UID may create/update/delete.
    match /flags/{flagId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == 'h6yAgTDOXxcavDyNA5dqJsvgcVR2';
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
