# Copy to .env.local. These are public web-SDK values, not secrets — Firestore
# rules are the actual security boundary. The admin allowlist below restricts
# who can read/write the flags collection from this site.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Comma-separated list of Firebase Auth UIDs allowed into /admin.
# Get yours from the Firebase console -> Authentication -> Users.
NEXT_PUBLIC_ADMIN_UIDS=

# Second Firebase project that owns a flag the admin portal edits (e.g. the
# NextBite mobile app). The portal authenticates against the project above but
# writes flag docs into this project's Firestore, where that app reads them.
# Cross-project writes are authorized by email in this project's rules.
NEXT_PUBLIC_NEXTBITE_FIREBASE_API_KEY=
NEXT_PUBLIC_NEXTBITE_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_NEXTBITE_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_NEXTBITE_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_NEXTBITE_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_NEXTBITE_FIREBASE_APP_ID=
